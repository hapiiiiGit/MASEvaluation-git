sequenceDiagram
    participant P as Player
    participant G as Game
    participant A as Admin
    P->>G: join_game()
    G->>P: welcome_message
    P->>G: place_bet(amount)
    G->>G: deal_cards()
    G->>P: show_cards()
    P->>G: decide_action()
    G->>G: calculate_winner()
    G->>P: show_winner()
    A->>G: monitor_players()
    A->>G: set_table_limits(min, max)