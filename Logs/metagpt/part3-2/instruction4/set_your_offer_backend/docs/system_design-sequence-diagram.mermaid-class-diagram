classDiagram
    class User {
        +id: int
        +name: str
        +email: str
        +password_hash: str
        +social_auth: dict
        +registration_date: datetime
        +last_login: datetime
        +preferences: dict
        +authenticate(password: str) -> bool
        +register(data: dict) -> User
    }
    class Session {
        +id: int
        +user_id: int
        +token: str
        +created_at: datetime
        +expires_at: datetime
        +create_session(user: User) -> Session
        +validate_token(token: str) -> bool
    }
    class Ad {
        +id: int
        +user_id: int
        +title: str
        +description: str
        +category: str
        +price: float
        +location: str
        +images: list[str]
        +status: str
        +created_at: datetime
        +updated_at: datetime
        +create_ad(data: dict) -> Ad
        +update_ad(ad_id: int, data: dict) -> Ad
        +delete_ad(ad_id: int) -> bool
    }
    class Recommendation {
        +id: int
        +user_id: int
        +ad_id: int
        +score: float
        +generated_at: datetime
        +generate(user: User) -> list[Ad]
    }
    class SearchLog {
        +id: int
        +user_id: int
        +query: str
        +filters: dict
        +timestamp: datetime
        +log_search(user: User, query: str, filters: dict) -> SearchLog
    }
    class Analytics {
        +get_dashboard_data(user: User) -> dict
    }
    class AdminTools {
        +moderate_ad(ad_id: int, action: str) -> bool
    }
    User "1" -- "*" Ad : owns
    User "1" -- "*" Session : sessions
    User "1" -- "*" Recommendation : recommendations
    User "1" -- "*" SearchLog : search_logs
    Ad "1" -- "*" Recommendation : recommended_in
