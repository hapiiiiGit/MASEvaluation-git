classDiagram
    class User {
        +user_id: int
        +username: str
        +email: str
        +password: str
        +created_at: datetime
        +authenticate(password: str) bool
    }
    class Document {
        +document_id: int
        +user: User
        +filename: str
        +file_type: str
        +uploaded_at: datetime
        +content: str
        +parse() str
    }
    class Summary {
        +summary_id: int
        +document: Document
        +user: User
        +summary_text: str
        +created_at: datetime
        +generate(document: Document) str
    }
    class Formula {
        +formula_id: int
        +user: User
        +name: str
        +expression: str
        +created_at: datetime
        +evaluate(variables: dict) float
        +save()
        +load(formula_id: int)
    }
    class FormulaResult {
        +result_id: int
        +formula: Formula
        +user: User
        +input_data: dict
        +result: float
        +created_at: datetime
    }
    User "1" -- "*" Document: uploads
    User "1" -- "*" Summary: owns
    User "1" -- "*" Formula: creates
    Document "1" -- "1" Summary: summarized_by
    Formula "1" -- "*" FormulaResult: produces
