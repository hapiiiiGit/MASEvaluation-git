classDiagram
    class User {
        +id: int
        +username: str
        +email: str
        +password: str
        +is_active: bool
        +created_at: datetime
        +login()
        +register()
    }
    class Document {
        +id: int
        +owner: User
        +file_name: str
        +file_type: str
        +upload_time: datetime
        +summary: str
        +content: str
        +upload(file)
        +generate_summary()
        +get_summary()
    }
    class Formula {
        +id: int
        +owner: User
        +name: str
        +expression: str
        +variables: dict
        +created_at: datetime
        +shared_with: list[User]
        +calculate(inputs: dict) -> float
        +save()
        +edit()
        +delete()
        +share(user: User)
    }
    class DocumentSerializer {
        +to_representation(instance: Document) -> dict
        +from_representation(data: dict) -> Document
    }
    class FormulaSerializer {
        +to_representation(instance: Formula) -> dict
        +from_representation(data: dict) -> Formula
    }
    class DocumentViewSet {
        +list(request)
        +retrieve(request, pk)
        +create(request)
        +destroy(request, pk)
    }
    class FormulaViewSet {
        +list(request)
        +retrieve(request, pk)
        +create(request)
        +update(request, pk)
        +destroy(request, pk)
        +share(request, pk)
    }
    User "1" --o "*" Document : owns
    User "1" --o "*" Formula : owns
    Formula "*" --o "*" User : shared_with
    DocumentViewSet ..> DocumentSerializer
    FormulaViewSet ..> FormulaSerializer
    DocumentViewSet ..> Document
    FormulaViewSet ..> Formula
