# Meta Cloud API (WhatsApp) credentials
META_TOKEN=your_meta_cloud_api_token
META_PHONE_NUMBER_ID=your_meta_phone_number_id
META_API_VERSION=v18.0
META_VERIFY_TOKEN=your_webhook_verify_token

# OpenAI ChatGPT API key
OPENAI_API_KEY=your_openai_api_key

# Database connection string (PostgreSQL example)
DATABASE_URL=postgresql+psycopg2://username:password@db_host:5432/your_database

# JWT configuration for admin authentication
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP configuration for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Dashboard session secret key
DASHBOARD_SECRET_KEY=your_dashboard_secret_key