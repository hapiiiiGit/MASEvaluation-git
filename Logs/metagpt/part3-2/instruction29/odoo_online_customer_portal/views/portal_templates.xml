<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Customer Portal Dashboard -->
    <template id="portal_dashboard" name="Customer Portal Dashboard">
        <t t-call="website.layout">
            <div class="o_portal_dashboard">
                <div class="container">
                    <div class="row">
                        <div class="col-md-3 o_portal_sidebar">
                            <nav class="nav flex-column">
                                <a class="nav-link active" href="/my/portal">Dashboard</a>
                                <a class="nav-link" href="/my/profile">Profile</a>
                                <a class="nav-link" href="/my/consent_status">Consent Status</a>
                            </nav>
                        </div>
                        <div class="col-md-9 o_portal_main">
                            <h2>Welcome, <t t-esc="user.name"/>!</h2>
                            <p>Your email: <t t-esc="user.email"/></p>
                            <t t-if="consent">
                                <div class="alert alert-info">
                                    <strong>Consent Status:</strong>
                                    <span t-if="consent.consent_given" class="text-success">Accepted</span>
                                    <span t-if="not consent.consent_given" class="text-danger">Not Accepted</span>
                                    <br/>
                                    <strong>Terms Version:</strong> <t t-esc="consent.terms_version"/>
                                    <br/>
                                    <strong>Jurisdiction:</strong> <t t-esc="consent.jurisdiction"/>
                                    <br/>
                                    <strong>Date:</strong> <t t-esc="consent.consent_date"/>
                                </div>
                            </t>
                            <t t-if="not consent">
                                <div class="alert alert-warning">
                                    You have not accepted the Terms &amp; Conditions yet.
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Profile Page with Consent Status -->
    <template id="portal_profile" name="Customer Profile">
        <t t-call="website.layout">
            <div class="o_portal_profile container">
                <h2>Profile</h2>
                <ul class="list-group">
                    <li class="list-group-item"><strong>Name:</strong> <t t-esc="user.name"/></li>
                    <li class="list-group-item"><strong>Email:</strong> <t t-esc="user.email"/></li>
                    <li class="list-group-item">
                        <strong>Consent Status:</strong>
                        <span t-if="consent and consent.consent_given" class="text-success">Accepted</span>
                        <span t-if="consent and not consent.consent_given" class="text-danger">Not Accepted</span>
                        <span t-if="not consent" class="text-warning">No Consent Record</span>
                    </li>
                    <li class="list-group-item" t-if="consent">
                        <strong>Terms Version:</strong> <t t-esc="consent.terms_version"/>
                        <br/>
                        <strong>Jurisdiction:</strong> <t t-esc="consent.jurisdiction"/>
                        <br/>
                        <strong>Date:</strong> <t t-esc="consent.consent_date"/>
                    </li>
                </ul>
            </div>
        </t>
    </template>

    <!-- Registration/Login Form with Terms & Conditions Checkbox -->
    <template id="portal_registration_form" name="Portal Registration Form">
        <t t-call="website.layout">
            <div class="o_portal_registration container">
                <h2>Register</h2>
                <form id="portal_registration_form" method="post" action="/web/signup">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" name="name" id="name" class="form-control" required="required"/>
                    </div>
                    <div class="form-group">
                        <label for="login">Email</label>
                        <input type="email" name="login" id="login" class="form-control" required="required"/>
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" name="password" id="password" class="form-control" required="required"/>
                    </div>
                    <div class="form-group form-check">
                        <input type="checkbox" class="form-check-input" id="terms_checkbox" name="terms_checkbox" required="required"/>
                        <label class="form-check-label" for="terms_checkbox">
                            I accept the <a href="/terms" target="_blank">Terms &amp; Conditions</a>
                        </label>
                    </div>
                    <input type="hidden" name="terms_version" value="v1.0"/>
                    <input type="hidden" name="jurisdiction" value="GDPR"/>
                    <button type="submit" class="btn btn-primary">Register</button>
                </form>
            </div>
        </t>
    </template>

    <!-- Consent Status Display (for AJAX) -->
    <template id="portal_consent_status" name="Consent Status">
        <div class="o_portal_consent_status">
            <t t-if="consent_given">
                <span class="badge badge-success">Accepted</span>
            </t>
            <t t-if="not consent_given">
                <span class="badge badge-danger">Not Accepted</span>
            </t>
            <br/>
            <strong>Terms Version:</strong> <t t-esc="terms_version"/>
            <br/>
            <strong>Jurisdiction:</strong> <t t-esc="jurisdiction"/>
            <br/>
            <strong>Date:</strong> <t t-esc="consent_date"/>
        </div>
    </template>
</odoo>