classDiagram
    class ChatbotAPI {
        +post_message(user_id: str, message: str) -> dict
        +get_history(user_id: str) -> list
    }
    class OpenAIClient {
        +__init__(api_key: str)
        +generate_response(prompt: str) -> str
    }
    class Utils {
        +sanitize_input(text: str) -> str
        +log_event(event: str)
    }
    class UserSession {
        +user_id: str
        +history: list
        +add_message(message: str)
        +get_history() -> list
    }
    ChatbotAPI --> OpenAIClient : uses
    ChatbotAPI --> Utils : uses
    ChatbotAPI --> UserSession : manages
    UserSession <.. ChatbotAPI : created by
