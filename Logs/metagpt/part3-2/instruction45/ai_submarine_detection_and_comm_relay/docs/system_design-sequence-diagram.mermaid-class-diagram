classDiagram
    class Main {
        <<entry point>>
        +__init__(config: Config)
        +run()
    }
    class DetectionEngine {
        +__init__(model_path: str, threshold: float)
        +process_stream(data: np.ndarray) -> DetectionResult
        +load_model(model_path: str)
        +set_threshold(threshold: float)
    }
    class CommunicationRelay {
        +__init__(config: Config)
        +switch_link(signal_quality: float) -> str
        +send_data(data: bytes, link_type: str)
        +get_status() -> str
    }
    class Logger {
        +__init__(log_path: str)
        +log_event(event: dict)
        +log_error(error: Exception)
        +get_logs() -> list
    }
    class Config {
        +__init__(config_file: str)
        +get(key: str) -> Any
        +set(key: str, value: Any)
    }
    class DetectionResult {
        +__init__(timestamp: float, detected: bool, confidence: float, details: dict)
    }
    class Benchmark {
        +__init__(detection_engine: DetectionEngine, relay: CommunicationRelay)
        +run_tests(test_data: list)
        +report() -> dict
    }
    Main --> DetectionEngine
    Main --> CommunicationRelay
    Main --> Logger
    Main --> Config
    DetectionEngine --> DetectionResult
    Benchmark --> DetectionEngine
    Benchmark --> CommunicationRelay
