    class User {
        +id: int
        +username: str
        +email: str
        +password: str
        +role: str
        +profile: Profile
        +__init__(username: str, email: str, password: str, role: str)
    }
    class Profile {
        +id: int
        +user: User
        +full_name: str
        +bio: str
        +avatar: str
        +contact_info: str
        +__init__(user: User, full_name: str, bio: str, avatar: str, contact_info: str)
    }
    class DelegateProfile {
        +interests: list[str]
        +tickets: list[Ticket]
        +__init__(profile: Profile, interests: list[str])
    }
    class OrganizerProfile {
        +organization: str
        +events: list[Event]
        +__init__(profile: Profile, organization: str)
    }
    class SpeakerProfile {
        +sessions: list[Session]
        +expertise: list[str]
        +__init__(profile: Profile, expertise: list[str])
    }
    class Event {
        +id: int
        +title: str
        +description: str
        +category: str
        +location: str
        +start_time: datetime
        +end_time: datetime
        +organizer: OrganizerProfile
        +speakers: list[SpeakerProfile]
        +tickets: list[Ticket]
        +__init__(...)
    }
    class Session {
        +id: int
        +event: Event
        +title: str
        +speaker: SpeakerProfile
        +schedule: datetime
        +__init__(...)
    }
    class Ticket {
        +id: int
        +event: Event
        +delegate: DelegateProfile
        +price: float
        +status: str
        +qr_code: str
        +order: Order
        +__init__(...)
    }
    class Order {
        +id: int
        +delegate: DelegateProfile
        +tickets: list[Ticket]
        +amount: float
        +payment_status: str
        +created_at: datetime
        +refund_status: str
        +__init__(...)
    }
    class Payment {
        +id: int
        +order: Order
        +provider: str
        +transaction_id: str
        +status: str
        +__init__(...)
    }
    class ChatbotSession {
        +id: int
        +user: User
        +messages: list[ChatMessage]
        +context: str
        +__init__(...)
    }
    class ChatMessage {
        +id: int
        +session: ChatbotSession
        +sender: str
        +content: str
        +timestamp: datetime
        +__init__(...)
    }
    class Admin {
        +id: int
        +user: User
        +dashboard: AdminDashboard
        +__init__(...)
    }
    class AdminDashboard {
        +id: int
