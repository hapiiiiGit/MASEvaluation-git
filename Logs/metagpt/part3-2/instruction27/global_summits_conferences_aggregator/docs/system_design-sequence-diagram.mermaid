sequenceDiagram
    participant U as User
    participant Auth as AuthSystem
    participant Prof as Profile
    participant E as Event
    participant T as Ticketing
    participant P as Payment
    participant CB as Chatbot
    participant AD as AdminDashboard

    U->>Auth: register(username, email, password, role)
    Auth-->>U: registration success
    U->>Prof: create/update profile
    Prof-->>U: profile saved
    U->>E: browse/search events
    E-->>U: return event list
    U->>E: view event details(event_id)
    E-->>U: return event details
    U->>T: purchase ticket(event_id)
    T->>P: initiate payment(order_id, provider)
    P-->>T: payment status
    T-->>U: ticket confirmation (QR code)
    U->>CB: start chatbot session (query)
    CB-->>U: chatbot response (event info, FAQ, recommendations)
    Organizer->>E: create/manage event
    E-->>Organizer: event created/updated
    Speaker->>Prof: update speaker profile/sessions
    Prof-->>Speaker: profile/sessions updated
    Admin->>AD: access dashboard
    AD-->>Admin: analytics, monetization controls
    Admin->>E: manage events (approve, feature, remove)
    E-->>Admin: event status updated
    Admin->>Prof: manage users (approve, suspend)
    Prof-->>Admin: user status updated
