sequenceDiagram
    participant U as User
    participant UI as KivyUI
    participant AU as AuthService
    participant LB as LogEntry
    participant PH as Photo
    participant OC as OCRService
    participant SI as Signature
    participant VA as ValidationService
    participant CL as CloudService
    participant EX as ExportService

    U->>UI: Launch app
    UI->>AU: login_oauth(provider)
    AU-->>UI: User object
    UI->>LB: create LogEntry(data)
    UI->>PH: add_photo(photo)
    PH-->>LB: Photo object
    UI->>OC: extract_text(image_path)
    OC-->>LB: OCR text
    UI->>SI: add_signature(signature)
    SI-->>LB: Signature object
    UI->>VA: validate_entry(entry, instructor)
    VA-->>LB: Validation status
    UI->>CL: sync_logbook(user)
    CL-->>LB: Sync status
    UI->>EX: export_pdf(log_entries)
    EX-->>UI: PDF file
    UI->>AU: logout(user)
    AU-->>UI: Logout success