#:kivy 2.1.0

<DashboardScreen>:
    name: 'dashboard'
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(16)

        # Header
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            Label:
                text: "Digital Diver's Logbook"
                font_size: '20sp'
                bold: True
                color: 0, 0.5, 0.7, 1
            Button:
                text: "Logout"
                size_hint_x: None
                width: dp(80)
                on_release: app.logout()

        # Dive Log Summary
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 0.95, 0.98, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [12]
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "Total Dives"
                    font_size: '16sp'
                    color: 0.2, 0.2, 0.2, 1
                Label:
                    id: total_dives
                    text: str(app.logbook.get_total_dives())
                    font_size: '24sp'
                    color: 0, 0.5, 0.7, 1
            BoxLayout:
                orientation: 'vertical'
                Label:
                    text: "Recent Location"
                    font_size: '16sp'
                    color: 0.2, 0.2, 0.2, 1
                Label:
                    id: recent_location
                    text: app.logbook.get_recent_location()
                    font_size: '18sp'
                    color: 0, 0.5, 0.7, 1

        # Quick Add Button
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            Widget:
            Button:
                text: "Add Dive Log"
                size_hint_x: None
                width: dp(180)
                background_color: 0, 0.5, 0.7, 1
                color: 1, 1, 1, 1
                font_size: '18sp'
                on_release: app.open_log_entry()
            Widget:

        # Recent Activity List
        Label:
            text: "Recent Activity"
            font_size: '16sp'
            color: 0.2, 0.2, 0.2, 1
            size_hint_y: None
            height: dp(32)
            bold: True

        ScrollView:
            size_hint_y: 0.35
            GridLayout:
                id: recent_activity_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                row_default_height: dp(56)
                row_force_default: True
                # Items will be dynamically added from Python

        # Navigation Buttons
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)
            Button:
                text: "Export"
                background_color: 0.8, 0.9, 1, 1
                color: 0, 0.5, 0.7, 1
                font_size: '16sp'
                on_release: app.open_export()
            Button:
                text: "Settings"
                background_color: 0.8, 0.9, 1, 1
                color: 0, 0.5, 0.7, 1
                font_size: '16sp'
                on_release: app.sm.current = 'login'