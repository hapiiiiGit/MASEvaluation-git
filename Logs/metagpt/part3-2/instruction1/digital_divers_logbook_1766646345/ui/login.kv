#:kivy 2.1.0

<LoginScreen>:
    name: 'login'
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(32), dp(32), dp(32), dp(32)

        # Header
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            Label:
                text: "Sign In"
                font_size: '22sp'
                bold: True
                color: 0, 0.5, 0.7, 1

        # Status/Error Message
        Label:
            id: status_label
            text: ""
            color: 1, 0, 0, 1
            font_size: '14sp'
            size_hint_y: None
            height: dp(24)

        # Username/Email Field
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(72)
            Label:
                text: "Username or Email"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_y: None
                height: dp(24)
            TextInput:
                id: username_input
                hint_text: "Enter your username or email"
                multiline: False
                write_tab: False
                size_hint_y: None
                height: dp(40)

        # Password Field
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(72)
            Label:
                text: "Password"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_y: None
                height: dp(24)
            TextInput:
                id: password_input
                hint_text: "Enter your password"
                password: True
                multiline: False
                write_tab: False
                size_hint_y: None
                height: dp(40)

        # Login Button
        Button:
            text: "Login"
            size_hint_y: None
            height: dp(48)
            background_color: 0, 0.5, 0.7, 1
            color: 1, 1, 1, 1
            font_size: '18sp'
            on_release:
                app.auth_service.login(
                    username_input.text,
                    password_input.text,
                    status_label
                )

        # OAuth2/Social Login Options
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            spacing: dp(10)
            Label:
                text: "Or sign in with:"
                font_size: '14sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_x: None
                width: dp(110)
            Button:
                text: "Google"
                size_hint_x: None
                width: dp(90)
                background_color: 0.9, 0.3, 0.2, 1
                color: 1, 1, 1, 1
                on_release: app.auth_service.oauth_login('google', status_label)
            Button:
                text: "Dropbox"
                size_hint_x: None
                width: dp(90)
                background_color: 0.1, 0.5, 0.9, 1
                color: 1, 1, 1, 1
                on_release: app.auth_service.oauth_login('dropbox', status_label)

        # Biometric Authentication (if available)
        Button:
            text: "Login with Biometrics"
            size_hint_y: None
            height: dp(44)
            background_color: 0.8, 0.9, 1, 1
            color: 0, 0.5, 0.7, 1
            font_size: '16sp'
            on_release: app.auth_service.biometric_login(status_label)

        # Register / Forgot Password
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)
            Button:
                text: "Register"
                background_color: 0, 0, 0, 0
                color: 0, 0.5, 0.7, 1
                font_size: '14sp'
                on_release: app.auth_service.open_registration()
            Button:
                text: "Forgot Password?"
                background_color: 0, 0, 0, 0
                color: 0, 0.5, 0.7, 1
                font_size: '14sp'
                on_release: app.auth_service.open_password_reset()