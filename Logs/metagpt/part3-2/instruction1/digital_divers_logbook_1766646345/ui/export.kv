#:kivy 2.1.0

<ExportScreen>:
    name: 'export'
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(16)

        # Header
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            Label:
                text: "Export & Share"
                font_size: '20sp'
                bold: True
                color: 0, 0.5, 0.7, 1
            Button:
                text: "Back"
                size_hint_x: None
                width: dp(80)
                on_release: app.open_dashboard()

        # Export Format Selection
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)
            Label:
                text: "Export Format:"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_x: None
                width: dp(120)
            ToggleButton:
                id: pdf_toggle
                text: "PDF"
                group: "export_format"
                state: "down"
            ToggleButton:
                id: csv_toggle
                text: "CSV"
                group: "export_format"
            ToggleButton:
                id: img_toggle
                text: "Image"
                group: "export_format"

        # Template Selection
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)
            Label:
                text: "Template:"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_x: None
                width: dp(120)
            Spinner:
                id: template_spinner
                text: "Default"
                values: ["Default", "Summary", "Detailed", "Custom"]
                size_hint_x: None
                width: dp(160)

        # Cloud Sync/Export Options
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)
            Label:
                text: "Cloud Export:"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_x: None
                width: dp(120)
            ToggleButton:
                id: gdrive_toggle
                text: "Google Drive"
                group: "cloud_export"
            ToggleButton:
                id: dropbox_toggle
                text: "Dropbox"
                group: "cloud_export"
            ToggleButton:
                id: s3_toggle
                text: "S3"
                group: "cloud_export"
            ToggleButton:
                id: local_toggle
                text: "Local"
                group: "cloud_export"
                state: "down"

        # Share Controls
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)
            Label:
                text: "Share:"
                font_size: '16sp'
                color: 0.2, 0.2, 0.2, 1
                size_hint_x: None
                width: dp(120)
            Button:
                text: "Email"
                size_hint_x: None
                width: dp(100)
                background_color: 0, 0.5, 0.7, 1
                color: 1, 1, 1, 1
                on_release: app.export_service.share_via_email(
                    pdf_toggle.state == "down",
                    csv_toggle.state == "down",
                    img_toggle.state == "down",
                    template_spinner.text
                )
            Button:
                text: "Other Apps"
                size_hint_x: None
                width: dp(120)
                background_color: 0, 0.5, 0.7, 1
                color: 1, 1, 1, 1
                on_release: app.export_service.share_via_apps(
                    pdf_toggle.state == "down",
                    csv_toggle.state == "down",
                    img_toggle.state == "down",
                    template_spinner.text
                )

        # Export Button
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(56)
            Widget:
            Button:
                text: "Export"
                size_hint_x: None
                width: dp(180)
                background_color: 0, 0.5, 0.7, 1
                color: 1, 1, 1, 1
                font_size: '18sp'
                on_release: app.export_service.export_data(
                    pdf_toggle.state == "down",
                    csv_toggle.state == "down",
                    img_toggle.state == "down",
                    template_spinner.text,
                    gdrive_toggle.state == "down",
                    dropbox_toggle.state == "down",
                    s3_toggle.state == "down",
                    local_toggle.state == "down"
                )
            Widget: