classDiagram
    class Main {
        +run() None
    }
    class Installer {
        +detect_python() bool
        +download_python(version: str, arch: str) str
        +install_python(installer_path: str) bool
    }
    class EnvManager {
        +set_env_vars(vars: dict) None
        +verify_env_vars(vars: list[str]) bool
    }
    class DependencyChecker {
        +check_requirements(req_file: str) list[str]
        +install_requirements(req_file: str) bool
    }
    class Compiler {
        +compile_with_pyinstaller(script: str, options: dict) str
        +compile_with_cxfreeze(script: str, options: dict) str
    }
    class Tester {
        +run_tests(exe_path: str, users: list[str]) dict
        +report_results(results: dict) None
    }
    class Logger {
        +log_info(msg: str) None
        +log_error(msg: str) None
        +log_debug(msg: str) None
    }
