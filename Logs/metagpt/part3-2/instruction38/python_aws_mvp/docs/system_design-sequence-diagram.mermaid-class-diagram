classDiagram
    class Main {
        <<entry point>>
        +run() None
    }
    class AuthManager {
        +login(email: str, password: str) dict
        +register(email: str, password: str) dict
        +verify_token(token: str) bool
    }
    class StorageManager {
        +generate_presigned_url(user_id: str, filename: str) str
        +validate_upload(user_id: str, file_metadata: dict) bool
    }
    class BillingManager {
        +create_customer(user_id: str) str
        +meter_usage(user_id: str, usage: float) None
        +create_subscription(user_id: str, plan_id: str) str
        +get_invoice(user_id: str) dict
    }
    class ObservabilityManager {
        +log_event(event: dict) None
        +track_error(error: Exception) None
        +get_metrics() dict
    }
    class API {
        +auth_routes()
        +storage_routes()
        +billing_routes()
        +observability_routes()
    }
    class User {
        +user_id: str
        +email: str
        +roles: list[str]
    }
    class FileUpload {
        +file_id: str
        +user_id: str
        +filename: str
        +status: str
    }
    Main --> API
    API --> AuthManager
    API --> StorageManager
    API --> BillingManager
    API --> ObservabilityManager
    AuthManager --> User
    StorageManager --> FileUpload
    BillingManager --> User
    ObservabilityManager --> API
